{
  "name": "leak-hunter",
  "version": "0.2.0",
  "description": "Cross-platform repository secret scanner",
  "bin": {
    "leak-hunter": "npm/cli.cjs"
  },
  "scripts": {
    "build:docs": "tailwindcss -i public/src/styles.css -o public/assets/site.css --minify",
    "postinstall": "node npm/postinstall.cjs",
    "test": "node --test tests/postinstall.test.cjs",
    "prepublishOnly": "npm test && npm pack --dry-run && node npm/prepublish-check.cjs"
  },
  "files": [
    "npm/cli.cjs",
    "npm/postinstall.cjs",
    "npm/prepublish-check.cjs",
    "README.md",
    "README.*.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doggy8088/leak-hunter.git"
  },
  "keywords": [
    "secret-scanner",
    "security",
    "cli"
  ],
  "author": "Will 保哥",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
